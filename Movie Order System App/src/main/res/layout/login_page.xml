<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wallpaper">

    <TextView
        android:id="@+id/login_info"
        android:layout_width="match_parent"
        android:layout_height="913dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="-401dp"
        android:background="@drawable/button_login"
        android:scrollbarDefaultDelayBeforeFade="400"
        android:scrollbarFadeDuration="250"
        android:scrollbarSize="4dp"
        android:scrollbarStyle="outsideInset"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/welcome"
        android:layout_width="167dp"
        android:layout_height="68dp"
        android:layout_alignTop="@+id/sign_info"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="34dp"
        android:layout_marginTop="35dp"
        android:layout_marginEnd="157dp"
        android:layout_marginBottom="367dp"
        android:text="Hello there!Welcome Back"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="normal" />

    <TextView
        android:id="@+id/Login"
        android:layout_width="156dp"
        android:layout_height="52dp"
        android:layout_alignTop="@+id/login_info"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="34dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="221dp"
        android:layout_marginBottom="455dp"
        android:text="Login"
        android:textColor="#01463F"
        android:textSize="35sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/username"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@+id/login_info"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="34dp"
        android:layout_marginTop="152dp"
        android:layout_marginEnd="215dp"
        android:layout_marginBottom="393dp"
        android:text="Username"
        android:textAllCaps="true"
        android:textColor="#01463F"
        android:textSize="14sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/enter_username"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_alignTop="@+id/login_info"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="31dp"
        android:layout_marginTop="172dp"
        android:layout_marginEnd="30dp"
        android:layout_marginBottom="300dp"
        android:drawableLeft="@drawable/person"
        android:ems="10"
        android:hint="Username"
        android:inputType="textPersonName" />

    <TextView
        android:id="@+id/password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@+id/login_info"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="34dp"
        android:layout_marginTop="222dp"
        android:layout_marginEnd="214dp"
        android:text="Password"
        android:textAllCaps="true"
        android:textColor="#01463F"
        android:textSize="14dp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/enter_password"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_alignTop="@+id/login_info"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="31dp"
        android:layout_marginTop="242dp"
        android:layout_marginEnd="30dp"
        android:layout_marginBottom="230dp"
        android:drawableLeft="@drawable/lock"
        android:ems="10"
        android:hint="Password"
        android:inputType="textPassword"
        android:textAlignment="textStart" />

    <TextView
        android:id="@+id/forget_pw"
        android:layout_width="129dp"
        android:layout_height="wrap_content"
        android:layout_alignTop="@+id/login_info"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="200dp"
        android:layout_marginTop="280dp"
        android:layout_marginEnd="30dp"
        android:backgroundTint="#ffffff"
        android:text="Forget Password?"
        android:textAllCaps="false"
        android:textColor="#01463F"
        android:textSize="16dp" />

    <Button
        android:id="@+id/LOGIN"
        android:layout_width="wrap_content"
        android:layout_height="37dp"
        android:layout_alignTop="@+id/login_info"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="31dp"
        android:layout_marginTop="320dp"
        android:layout_marginEnd="31dp"
        android:background="@drawable/button_login_success"
        android:text="LOGIN"
        android:textColor="#ffffff"
        android:textSize="20sp" />

    <Button
        android:id="@+id/login_with_google"
        android:layout_width="128dp"
        android:layout_height="34dp"
        android:layout_alignTop="@+id/login_info"
        android:layout_alignParentStart="true"
        android:layout_marginStart="195dp"
        android:layout_marginTop="412dp"
        android:background="@drawable/login_with_google"
        android:text="        GOOGLE"
        android:textAlignment="center"
        android:textColor="#ffffff"
        android:textSize="14sp"
        android:textStyle="bold" />

    <View
        android:id="@+id/line1"
        android:layout_width="120dp"
        android:layout_height="1dp"
        android:layout_alignTop="@+id/login_info"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="31dp"
        android:layout_marginTop="391dp"
        android:layout_marginEnd="220dp"
        android:background="#45000000" />

    <TextView
        android:id="@+id/or"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@+id/login_info"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="167dp"
        android:layout_marginTop="377dp"
        android:layout_marginEnd="167dp"
        android:text="OR"
        android:textSize="20sp" />

    <View
        android:id="@+id/line2"
        android:layout_width="120dp"
        android:layout_height="1dp"
        android:layout_alignTop="@+id/login_info"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="220dp"
        android:layout_marginTop="391dp"
        android:layout_marginEnd="31dp"
        android:background="#45000000" />

    <Button
        android:id="@+id/login_with_fb"
        android:layout_width="128dp"
        android:layout_height="34dp"
        android:layout_alignTop="@+id/login_info"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="412dp"
        android:layout_marginEnd="195dp"
        android:background="@drawable/login_with_fb"
        android:text="        FACEBOOK"
        android:textAlignment="center"
        android:textColor="#ffffff"
        android:textSize="14sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/fb"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_alignTop="@+id/login_info"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="416dp"
        android:layout_marginEnd="289dp"
        android:background="@drawable/facebook_icon"
        android:defaultFocusHighlightEnabled="false"
        android:singleLine="true"
        android:textAlignment="center"
        android:textColor="#ffffff"
        android:textSize="18sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/google"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_alignStart="@+id/login_with_google"
        android:layout_alignTop="@+id/login_info"
        android:layout_marginStart="24dp"
        android:layout_marginTop="418dp"
        android:background="@drawable/google_icon"
        android:defaultFocusHighlightEnabled="false"
        android:singleLine="true"
        android:textAlignment="center"
        android:textColor="#ffffff"
        android:textSize="18sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_above="@+id/login_info"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="1dp"
        android:layout_marginEnd="319dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/back" />

</RelativeLayout>